# Turnkey API credentials (from https://app.turnkey.com → API Keys)
TURNKEY_API_PUBLIC_KEY=your-api-public-key
TURNKEY_API_PRIVATE_KEY=your-api-private-key

# Parent organization ID (from https://app.turnkey.com → Settings)
TURNKEY_ORGANIZATION_ID=your-organization-id

# Server wallet compressed public key (66 hex chars, starts with 02 or 03)
#
# This must be a wallet created directly in the PARENT organization,
# NOT a sub-org wallet from react-wallet-kit authentication.
#
# To create one:
#   1. Go to https://app.turnkey.com → Wallets → Create Wallet
#   2. Add an account with:
#      - Curve: secp256k1
#      - Path format: BIP-32
#      - Path: m/44'/5757'/0'/0/0
#      - Address format: Compressed
#   3. Copy the public key from the account details
#
# Then fund the derived testnet address:
#   Run `pnpm demo -- --info` to see the address, then use the faucet:
#   https://explorer.hiro.so/sandbox/faucet?chain=testnet
SERVER_WALLET_PUBLIC_KEY=03your-compressed-public-key-here

# Optional: Turnkey API base URL override
# TURNKEY_BASE_URL=https://api.turnkey.com
