# Turnkey Configuration (required for wallet creation and auth)
# Get these from https://app.turnkey.com
NEXT_PUBLIC_TURNKEY_ORGANIZATION_ID=your-org-id
NEXT_PUBLIC_TURNKEY_AUTH_PROXY_CONFIG_ID=your-auth-proxy-config-id

# Optional: base URL override (defaults to https://api.turnkey.com)
TURNKEY_BASE_URL=https://api.turnkey.com

# Note: This demo uses client-side signing via the browser's httpClient.
# No server API keys or TURNKEY_SIGNER_PUBLIC_KEY are needed.
# The user's wallet key lives in their Turnkey sub-org, and the
# authenticated browser session handles signing directly.
